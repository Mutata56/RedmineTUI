#!/usr/bin/env python3
"""Список активных заявок для стеклянного меню Super+I.
Источники задаются в ~/.config/redmine-tui.conf (LIST_SOURCES, разделитель "||"),
фильтрует по статусам {1 Новая, 2 В работе, 49 Новая информация}, сортирует по обновлению.
Вывод TSV: id<TAB>status<TAB>subject<TAB>assignee<TAB>updated_on.
Кэш ~45с, повторное открытие меню мгновенное. Ключ из secret-tool (не в коде)."""
import concurrent.futures
import json
import os
import subprocess
import sys
import time
import urllib.request
import urllib.error
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import redmine_conf                       # единый конфиг (BASE), ~/.config/redmine-tui.conf
BASE = redmine_conf.BASE
WANT = {1, 2, 49}
TTL = 45
CACHE = Path.home() / ".cache" / "redmine-menu" / "list.tsv"
SHORT = {"В процессе: В работе": "В работе", "Новая информация": "Новая инфо", "Новая": "Новая"}

CACHE.parent.mkdir(parents=True, exist_ok=True)

# свежий кэш, отдаём мгновенно
try:
    if time.time() - CACHE.stat().st_mtime < TTL:
        sys.stdout.write(CACHE.read_text(encoding="utf-8"))
        sys.exit(0)
except FileNotFoundError:
    pass

key = subprocess.run(["secret-tool", "lookup", "service", "redmine-notify"],
                     capture_output=True, text=True).stdout
if not key:
    sys.stderr.write("нет ключа Redmine (secret-tool service=redmine-notify)\n")
    sys.exit(1)

# Источники из ~/.config/redmine-tui.conf (LIST_SOURCES); дефолт = все открытые заявки.
SOURCES = redmine_conf.LIST_SOURCES or ["status_id=open"]
def fetch_source(src):
    """Все issue одного источника (с пагинацией). Возвращает (list, network_failed)."""
    out, off = [], 0
    while True:
        url = f"{BASE}/issues.json?{src}&limit=100&offset={off}&sort=updated_on:desc"
        req = urllib.request.Request(url, headers={"X-Redmine-API-Key": key})
        try:
            d = json.load(urllib.request.urlopen(req, timeout=30))
        except Exception:
            return out, True
        batch = d.get("issues", [])
        out += batch
        off += len(batch)
        if off >= d.get("total_count", 0) or not batch:
            return out, False

with concurrent.futures.ThreadPoolExecutor(max_workers=max(1, len(SOURCES))) as ex:   # источники параллельно
    results = list(ex.map(fetch_source, SOURCES))

issues, seen, net_fail = [], set(), False
for lst, failed in results:
    net_fail = net_fail or failed
    for it in lst:
        if it["id"] not in seen:
            seen.add(it["id"])
            issues.append(it)

if net_fail and not issues:           # всё упало, отдаём кэш, иначе явная ошибка (не «пусто»)
    if CACHE.exists():
        sys.stderr.write("сеть недоступна — отдан кэш\n")
        sys.stdout.write(CACHE.read_text(encoding="utf-8"))
        sys.exit(0)
    sys.stderr.write("сеть недоступна, кэша нет\n")
    sys.exit(3)
if net_fail:                          # часть источников недоступна, список неполный (UI пометит)
    sys.stderr.write("часть источников недоступна — список неполный\n")

lines = []
for i in issues:
    st = (i.get("status") or {})
    if st.get("id") not in WANT:
        continue
    name = SHORT.get(st.get("name", ""), st.get("name", ""))
    assignee = (i.get("assigned_to") or {}).get("name", "—")
    project = (i.get("project") or {}).get("name", "—")
    subject = " ".join((i.get("subject") or "").split())
    lines.append(f"{i['id']}\t{name}\t{subject}\t{assignee}\t{i.get('updated_on', '')}\t{project}")

text = "\n".join(lines) + ("\n" if lines else "")
if not net_fail:                      # не затирать полный кэш частичным результатом
    tmp = CACHE.with_suffix(".tmp")   # атомарная запись: оборванная запись не оставит битый кэш
    tmp.write_text(text, encoding="utf-8")
    os.replace(tmp, CACHE)
sys.stdout.write(text)
