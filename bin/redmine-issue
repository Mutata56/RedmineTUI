#!/usr/bin/env python3
"""Превью одной заявки для стеклянного меню Super+I.
Вывод: строки key<TAB>value (QML парсит). При 404 печатает 'NOTFOUND'.
Ключ из secret-tool (service redmine-notify), не в коде."""
import json
import os
import subprocess
import sys
import urllib.request
import urllib.error

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import redmine_conf                       # единый конфиг (BASE), ~/.config/redmine-tui.conf
BASE = redmine_conf.BASE

num = "".join(c for c in (sys.argv[1] if len(sys.argv) > 1 else "") if c.isdigit())
if not num:
    sys.exit(1)

key = subprocess.run(["secret-tool", "lookup", "service", "redmine-notify"],
                     capture_output=True, text=True).stdout
if not key:
    sys.exit(1)

req = urllib.request.Request(f"{BASE}/issues/{num}.json",
                             headers={"X-Redmine-API-Key": key})
try:
    issue = json.load(urllib.request.urlopen(req, timeout=20))["issue"]
except urllib.error.HTTPError as e:
    if e.code == 404:
        print("NOTFOUND")
        sys.exit(0)
    sys.exit(1)
except Exception:
    sys.exit(1)


def name_of(field):
    v = issue.get(field)
    return v.get("name", "—") if isinstance(v, dict) else "—"


desc = " ".join((issue.get("description") or "").split())
if len(desc) > 200:
    desc = desc[:200] + "…"

rows = {
    "id": issue.get("id", ""),
    "subject": " ".join((issue.get("subject") or "").split()),
    "status": name_of("status"),
    "assignee": name_of("assigned_to"),
    "author": name_of("author"),
    "priority": name_of("priority"),
    "project": name_of("project"),
    "tracker": name_of("tracker"),
    "done": issue.get("done_ratio", 0),
    "updated": issue.get("updated_on", ""),
    "created": issue.get("created_on", ""),
    "desc": desc,
}
for k, v in rows.items():
    print(f"{k}\t{v}")
